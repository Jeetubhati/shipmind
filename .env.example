# ─── Required ────────────────────────────────────────────────────────────
# Anthropic API key — for Claude analysis. Get one at console.anthropic.com.
# Without it, ShipMind still runs queries; it just shows a stub analysis.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Source credentials (used by `coral source add ...`) ────────────────
# GitHub PAT with `repo` scope. github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Linear API key. linear.app/<workspace>/settings/api
LINEAR_API_KEY=lin_api_your_key_here

# Sentry user auth token. sentry.io/settings/account/api/auth-tokens/
# Note Coral expects SENTRY_TOKEN/SENTRY_ORG (not the older _AUTH_TOKEN/_ORG_SLUG names).
SENTRY_TOKEN=sntryu_your_token_here
SENTRY_ORG=your-sentry-org-slug

# Slack bot token (xoxb-…). Needs channels:read, channels:history,
# groups:history, users:read. api.slack.com/apps
SLACK_TOKEN=xoxb-your-token-here

# ─── Query targets (used by agent/queries.py) ───────────────────────────
GITHUB_ORG=withcoral
GITHUB_REPO=coral
LINEAR_ORG_SLUG=your-linear-slug
LINEAR_TEAM_KEY=SHI
SENTRY_ORG_SLUG=your-sentry-org-slug
SLACK_CHANNEL_ID=C0XXXXXXXXX

# ─── Optional ──────────────────────────────────────────────────────────
# Override the Claude model. Default: claude-sonnet-4-6 (current Sonnet, Jan 2026).
# CLAUDE_MODEL=claude-opus-4-7
